# ── EX05 environment template (example only) ─────────────────────────────────
# Copy to `.env` (which is git-ignored) and fill in locally if you ever need it.
# NOTE: none of these are required to INSPECT the committed results/analysis/figures.
#       The committed evidence is offline and credential-free.
# NEVER commit real secrets. `.env` is git-ignored; only this `.env-example` is tracked.

# Offline / local-only operation (the measured path uses a local Qwen2-0.5B cache).
EX05_OFFLINE=1
EX05_LOCAL_FILES_ONLY=1

# Primary measured model (already cached locally; not re-downloaded by this repo).
EX05_MODEL_ID=Qwen/Qwen2-0.5B
EX05_MODEL_CACHE_DIR=

# Optional tokens — leave blank. Not needed to inspect committed results.
# Only relevant if a user later opts into an (approved) download or a live API.
HF_TOKEN=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# External-API access stays DISABLED by default (no live API call is made anywhere;
# API costs in this project are assumption-based, not queried from a provider).
EX05_ENABLE_EXTERNAL_API=0
